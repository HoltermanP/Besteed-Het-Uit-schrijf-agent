{
  "name": "ai-schrijfagent-besteed-het-uit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "prisma generate && npm run migrate:deploy:safe && node scripts/build-api.mjs && tsc -b && vite build",
    "migrate:deploy:safe": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('prisma migrate deploy',{stdio:'inherit'})}else{console.log('Geen DATABASE_URL: migraties overgeslagen')}\"",
    "postinstall": "prisma generate",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "CI=true playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-accordion": "^1.2.14",
