# Admin-toegang (alleen jij). Zet dit in .env.local — niet committen.
VITE_ADMIN_PASSWORD=kies-een-sterk-wachtwoord

# PostgreSQL/Neon voor stijlbibliotheek (schrijfstijl & kwaliteit)
# Gebruik de pooler-URL voor runtime (Vercel/serverless):
# DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# Migraties lokaal draaien vóór deploy (niet via pooler-URL — die geeft advisory-lock timeouts):
# npm run migrate:deploy
# Optioneel: server-side AI voor schrijfagent en bedrijfsgegevens
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# WRITER_MODEL=claude-opus-4-8
# COMPANY_ENRICH_MODEL=claude-opus-4-8
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
