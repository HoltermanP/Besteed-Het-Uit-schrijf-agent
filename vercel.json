{
  "rewrites": [
    {
      "source": "/api/tenderned/:path*",
      "destination": "https://www.tenderned.nl/papi/tenderned-rs-tns/:path*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/company-enrich.js": {
      "maxDuration": 60
    },
    "api/write-draft.js": {
      "maxDuration": 300
    },
    "api/review-draft.js": {
      "maxDuration": 120
    },
    "api/rewrite-fragment.js": {
      "maxDuration": 120
    },
    "api/style-documents.js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/.prisma/client/**"
    },
    "api/lessons-learned.js": {
      "maxDuration": 30,
      "includeFiles": "node_modules/.prisma/client/**"
    },
    "api/evaluate-project.js": {
      "maxDuration": 120
    },
    "api/select-lessons.js": {
      "maxDuration": 90
    },
    "api/compare-projects.js": {
      "maxDuration": 120
    },
    "api/extract-text.js": {
      "maxDuration": 30
    },
    "api/tender-documents.js": {
      "maxDuration": 60
    }
  }
}
